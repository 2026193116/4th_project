# GameState 클래스 테스트
# =============================================
class TestGameState(unittest.TestCase):

    def test_initial_values(self):
        """초기 상태값 검증"""
        state = GameState()
        self.assertEqual(state.lives, INITIAL_LIVES)
        self.assertEqual(state.score, 0)
        self.assertEqual(state.level, INITIAL_LEVEL)
        self.assertEqual(state.words_cleared, 0)
        self.assertEqual(state.next_level_target, INITIAL_NEXT_LEVEL_TARGET)
        self.assertFalse(state.game_over)
        self.assertEqual(state.current_input, "")
        self.assertEqual(len(state.active_words), 0)

    def test_lose_life(self):
        """목숨 감소 확인"""
        state = GameState()
        state.lose_life()
        self.assertEqual(state.lives, 2)
        self.assertFalse(state.game_over)

    def test_lose_all_lives_game_over(self):
        """목숨이 0이 되면 game_over가 True"""
        state = GameState()
        state.lose_life()
        state.lose_life()
        state.lose_life()
        self.assertEqual(state.lives, 0)
        self.assertTrue(state.game_over)

    def test_add_score(self):
        """점수 추가 (레벨 비례) 확인"""
        state = GameState()
        state.add_score(100)
        self.assertEqual(state.score, 100)  # level  * 00
        self.assertEqual(state.words_cleared, 1)

    def test_add_score_higher_level(self):
        """높은 레벨에서의 점수 배수 확인"""
        state = GameState()
        state.level = 3
        state.add_score(100)
        self.assertEqual(state.score, 300)  # level  * 00

    def test_check_level_up_not_ready(self):
        """단어 클리어 수가 부족하면 레벨업하지 않음"""
        state = GameState()
        state.words_cleared = 5
        result = state.check_level_up(current_time=1000)
        self.assertFalse(result)
        self.assertEqual(state.level, 1)

    def test_check_level_up_triggered(self):
        """단어 클리어 수가 충분하면 레벨업"""
        state = GameState()
        state.words_cleared = 10  # next_level_target 기본값이 10
        result = state.check_level_up(current_time=5000)
        self.assertTrue(result)
        self.assertEqual(state.level, 2)
        self.assertEqual(state.level_up_time, 5000)
        # next_level_target이 증가했는지 확인
        self.assertGreater(state.next_level_target, 10)

    def test_check_level_up_target_formula(self):
        """레벨업 후 next_level_target 공식 확인: 기존 + 10 + (새 레벨 * 5)"""
        state = GameState()
        state.words_cleared = 10
        old_target = state.next_level_target  # 10
        state.check_level_up(current_time=0)
        expected = old_target + 10 + (state.level * 5)
        self.assertEqual(state.next_level_target, expected)

    def test_input_operations(self):
        """입력 조작 (추가, 백스페이스, 클리어) 확인"""
        state = GameState()
        state.append_input("H")
        state.append_input("i")
        self.assertEqual(state.current_input, "Hi")

        state.backspace_input()
        self.assertEqual(state.current_input, "H")

        state.clear_input()
        self.assertEqual(state.current_input, "")

    def test_backspace_on_empty_input(self):
        """빈 입력에서 백스페이스해도 에러 없음"""
        state = GameState()
        state.backspace_input()
        self.assertEqual(state.current_input, "")

if __name__ == '__main__':
    unittest.main()
